# بيت الصحافة (PressHouse) - ملف متغيرات البيئة التجريبي (Clean Template)
NODE_ENV=development
PORT=3000

# [DATABASE] إعدادات قاعدة البيانات بوستجرس المزدوجة (PostgreSQL with SQLite fallback)
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_HOST=
POSTGRES_DATABASE=
POSTGRES_USER=
POSTGRES_PASSWORD=

# [AI GATEWAY] إعدادات الذكاء الاصطناعي الأمني الحليف (Press Agent / OpenAI Compatible AI Gateway)
AI_API_KEY=
AI_BASE_URL=
AI_MODEL_PRIMARY=nvidia/nemotron-3-ultra-550b-a55b
GEMINI_API_KEY=

# [GENERAL]
VITE_API_URL=

# [SECURITY] مسارات مخصصة لتأمين وحماية مداخل الإدارة العامة
JWT_SECRET=super-secret-unique-hash-key-for-jwt-tokens-2026
VITE_ADMIN_PATH=/admin
VITE_ROOT_PATH=/root

# [SMTP] إعدادات البريد الإلكتروني SMTP
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# [ADMIN] إعدادات المستخدم الادمن الأولي
ADMIN_USER=admin
ADMIN_EMAIL=admin@ph-ye.org
ADMIN_PASSWORD=change-me-please



# [S3 STORAGE] إعدادات استيراد ومزامنة المواضيع من Amazon S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=

# [DATABASE & FIRECRAWL] إعدادات إضافية
DATABASE_URL=
DATABASE_URL_UNPOOLED=
PGHOST=
PGHOST_UNPOOLED=
PGUSER=
PGDATABASE=
PGPASSWORD=
POSTGRES_URL_NO_SSL=
POSTGRES_PRISMA_URL=
FIRECRAWL_API_KEY=

