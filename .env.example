# ============================================
# PressHouse Vercel - Environment Configuration
# Version: 2026.07.01
# ============================================

# ---- Railway Press House Services ----
# PressHouse Agent (AI Chat & Completion API)
PRESS_AGENT_URL=https://agent.ph-ye.org
PRESS_AGENT_API_KEY=your_press_agent_api_key_here
PRESS_AGENT_RAILWAY_SERVICE_ID=your_railway_service_id_here

# PressHouse Search Engine (SearXNG)
SEARCH_ENGINE_URL=https://search.ph-ye.org
SEARCH_ENGINE_SECRET_KEY=your_search_engine_secret_key_here
SEARCH_ENGINE_RAILWAY_SERVICE_ID=your_railway_service_id_here

# Railway Project Configuration
RAILWAY_PROJECT_ID=your_railway_project_id_here
RAILWAY_ENVIRONMENT_ID=your_railway_environment_id_here

# ---- Neon PostgreSQL ----
DATABASE_URL=your_neon_database_url_here
DATABASE_URL_UNPOOLED=your_neon_database_url_unpooled_here
POSTGRES_PRISMA_URL=your_postgres_prisma_url_here
PGHOST=your_neon_host_here
PGUSER=your_neon_user_here
PGDATABASE=your_neon_database_here
PGPASSWORD=your_neon_password_here

# ---- Redis ----
REDIS_URL=your_redis_url_here

# ---- Server ----
NODE_ENV=production

# ---- Vite / Frontend ----
VITE_API_URL=https://ph-ye.org
VITE_ADMIN_PATH=/admin

# ---- Security ----
JWT_SECRET=your_jwt_secret_here

# ---- Cloudflare DNS ----
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_ZONE_ID=your_cloudflare_zone_id_here
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here

# ---- SMTP ----
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=your_smtp_user_here
SMTP_PASSWORD=your_smtp_password_here
SMTP_FROM=your_smtp_from_here

# ---- Telegram Bot ----
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_BOT_USERNAME=your_telegram_bot_username_here
TELEGRAM_ALLOWED_USER_ID=your_telegram_user_id_here
TELEGRAM_ALLOWED_USERNAME=your_telegram_username_here

# ---- Vercel Blob Storage ----
BLOB_STORE_ID=your_blob_store_id_here
BLOB_READ_WRITE_TOKEN=your_blob_read_write_token_here

# ---- NVIDIA AI ----
NVIDIA_API_KEY=your_nvidia_api_key_here

# ---- Deployment Tokens ----
VERCEL_TOKEN=your_vercel_token_here
